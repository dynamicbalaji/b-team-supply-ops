# ── Copy this to .env and fill in your values ──────────────────────────
# NEVER commit .env to git

# Gemini (Phase 2) — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Upstash Redis (all phases) — free at https://upstash.com
# Create a Redis database → copy REST URL and token
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# TursoDB (Phase 3) — free at https://turso.tech
# turso db create resolveiq && turso db tokens create resolveiq
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_token_here

# App settings
CORS_ORIGIN=http://localhost:5173
PORT=8000
ENV=development
