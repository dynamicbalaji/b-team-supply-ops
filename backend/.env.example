# ── Copy this file to .env and fill in your values ───────────────────────
# NEVER commit .env to git — it contains secrets

# ── Gemini ───────────────────────────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model chain — tried left-to-right on any failure, rate-limit, or timeout.
# Edit this list and restart the server. No code changes ever needed.
# Rules:
#   • Names must be exact API strings accepted by google.generativeai
#   • Duplicates are silently ignored
#   • If the whole list fails, agents fall back to hardcoded demo text
#
# Model reference (June 2025):
#   gemini-2.0-flash               → primary; fast, generous free-tier quota
#   gemini-2.5-flash-preview-05-20 → API name for "gemini-3-flash-preview";
#                                     smarter, slightly more quota-constrained
#   gemini-2.5-flash               → stable GA alias (use when released)
#   gemma-3-27b-it                 → "gemma-3-47b" per Google marketing;
#                                     open-weight, very reliable availability
#   gemma-3-12b-it                 → lightest fallback, almost never rate-limited
#
GEMINI_MODEL_CHAIN=gemini-2.0-flash,gemini-2.5-flash-preview-05-20,gemini-2.5-flash,gemma-3-27b-it,gemma-3-12b-it

# Seconds to wait before timing out one model and trying the next.
# Increase if you see frequent timeouts on slower models (gemma).
GEMINI_MODEL_TIMEOUT=20

# How many times to retry the SAME model on a 429 rate-limit before moving on.
# Each retry waits GEMINI_RATE_LIMIT_BACKOFF * 2^attempt seconds:
#   attempt 0 → 1.5s,  attempt 1 → 3.0s,  attempt 2 → 6.0s
GEMINI_RATE_LIMIT_RETRIES=2
GEMINI_RATE_LIMIT_BACKOFF=1.5

# ── Upstash Redis (all phases) ────────────────────────────────────────────
# Free tier at: https://upstash.com
# Create a Redis database → copy REST URL and token below
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ── TursoDB (Phase 3) ─────────────────────────────────────────────────────
# Free tier at: https://turso.tech
# turso db create resolveiq && turso db tokens create resolveiq
TURSO_DATABASE_URL=https://your-db-name.turso.io?tls=1
TURSO_AUTH_TOKEN=your_turso_token_here

# ── App ───────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
PORT=8000
ENV=development
